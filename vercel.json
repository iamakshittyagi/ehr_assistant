{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/*.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/transcribe",        "dest": "/api/transcribe.py" },
    { "src": "/extract",           "dest": "/api/extract.py" },
    { "src": "/save",              "dest": "/api/save.py" },
    { "src": "/records/([^/]+)",   "dest": "/api/record.py?id=$1" },
    { "src": "/records",           "dest": "/api/records.py" },
    { "src": "/search",            "dest": "/api/search.py" },
    { "src": "/assets/(.*)",       "dest": "/public/assets/$1" },
    { "src": "/(.*)",              "dest": "/public/index.html" }
  ]
}